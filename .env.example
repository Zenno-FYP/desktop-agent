# Zenno Desktop Agent - Environment Variables Template
# 
# Copy this file to .env and fill in your actual values.
# IMPORTANT: .env is in .gitignore - never commit actual secrets!
# 
# Environment variable naming: dot notation converts to uppercase with underscores
# Example: firebase.api_key -> FIREBASE_API_KEY

# Firebase Configuration
# Get API key from: Firebase Console > Project Settings > Web API Key
FIREBASE_API_KEY=""
FIREBASE_PROJECT_ID=""

# Backend API Configuration
# Point to your NestJS backend that provides user profile endpoints
BACKEND_BASE_URL="http://localhost:3000/api/v1"


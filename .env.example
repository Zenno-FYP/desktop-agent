# -----------------------------------------------------------------------------
# Zenno Desktop Agent environment template
# Copy to `.env` in this folder and replace placeholder values.
# `.env` is git-ignored. Never commit real secrets.
# -----------------------------------------------------------------------------

# Firebase web config used by desktop auth bridge/webview.
FIREBASE_API_KEY="your-firebase-web-api-key"
FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
FIREBASE_PROJECT_ID="your-firebase-project-id"

# Backend API base URL (NestJS backend).
BACKEND_BASE_URL="http://localhost:3000/api/v1"

# Nudge NLP API (FastAPI service)
NUDGE_API_URL="http://localhost:8000"
NUDGE_API_SECRET="replace-with-long-random-secret"
NUDGE_API_TIMEOUT="8.0"

# Optional sync/poller timing overrides (seconds)
SYNC_TIMEOUT_SECONDS="30"
PREFS_POLL_INTERVAL_SEC="300"
NUDGE_SYNC_INTERVAL_SEC="300"

